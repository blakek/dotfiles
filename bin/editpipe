#!/usr/bin/env bash
set -euo pipefail

show_usage() {
	local script_name
	script_name=$(basename "$0")

	cat <<-EOF
		Edit stdin in \$VISUAL or \$EDITOR, then print the result to stdout.

		USAGE
		  some-command | ${script_name}
	EOF
}

editpipe() {
	case "${1:-}" in
		-h|--help|help)
			show_usage
			return
			;;
	esac

	local tmp=''
	local -a editor_command

	tmp="$(mktemp "${TMPDIR:-/tmp}/editpipe.XXXXXXXX")"
	trap '[[ -n "${tmp:-}" ]] && rm -f -- "$tmp"' EXIT INT TERM HUP

	cat > "$tmp"

	read -r -a editor_command <<< "${VISUAL:-${EDITOR:-vi}}"
	"${editor_command[@]}" "$tmp" </dev/tty >/dev/tty

	cat -- "$tmp"
}

editpipe "$@"
