#!/usr/bin/env bash

##
# A fancy timer that:
# - Can show time remaining, time elapsed, etc.
# - Can show a custom message
# - Can parse a time string (e.g. 1h30m20s)
# - Shows a reverse progress bar for a larger indicator of time remaining
##

fancy_timer_version="2.0.0"

bold() {
	echo -e "\033[1m$*\033[0m"
}

show_usage() {
	cat <<-END
		$(bold fancy_timer) - A fancy timer for the command line

		$(bold USAGE EXAMPLES)
			# Set a 20 minute timer
			fancy_timer 20m

			# Set a 1 hour timer with a custom message and no progress bar
			fancy_timer --no-progress -m "Time remaining: %r" 1h

		$(bold OPTIONS)
			-h, --help     output usage information and exit
			-v, --version  output the version number and exit
			-c, --color    what color to use for the progress bar (default: #FFA500; accepts hex colors)
			-m, --message  a template message to display; see below for syntax
			-s, --sleep    how long to sleep between updates (default: 100ms; accepts time strings like 1s, 500ms, etc.)

			--no-color     disable color output
			--no-progress  disable the progress bar

		$(bold ARGUMENTS)
			time      time to count down from (e.g. 1h23m45s)

		$(bold MESSAGE SYNTAX)
			The message is a string where the following are replaced:
				%r  time remaining
				%e  time elapsed
				%t  total time

			Note, all time values are in the format 1h23m45s.
	END
}

panic() {
	red="\033[31m"
	reset="\033[0m"
	echo -e "${red}Error: $*${reset}" >&2
	exit 1
}

# Sources required dependencies
init() {
	local bk_lib_location
	bk_lib_location="$(realpath "$DOTFILES_ROOT/lib/bk.sh")"

	source "$bk_lib_location" || panic "Failed to source bk library"
}

# Returns the current time in microseconds
usec() {
	echo "${EPOCHREALTIME//.}"
}

# Sleeps for a given number of microseconds
usleep() {
	local duration="$1"
	if [[ -z "$duration" || "$duration" -le 0 ]]; then
		return
	fi

	# Convert microseconds to seconds for the sleep command
	local seconds=$(awk "BEGIN {printf \"%.6f\", $duration / 1000000}")
	sleep "$seconds"
}

# Parse a time string (e.g. 1h30m20s) into microseconds
parse_time() {
	local input="${1//[[:space:]]/}"
	local total=0
	local value unit rest factor

	[[ -n "$input" ]] || {
		echo "parse_time: empty duration" >&2
		return 2
	}

	while [[ -n "$input" ]]; do
		if [[ "$input" =~ ^([0-9]+)(us|μs|ms|d|h|m|s)(.*)$ ]]; then
			value="${BASH_REMATCH[1]}"
			unit="${BASH_REMATCH[2]}"
			rest="${BASH_REMATCH[3]}"

			case "$unit" in
				us|µs) factor=1 ;;
				ms) factor=1000 ;;
				s) factor=1000000 ;;
				m) factor=60000000 ;;
				h) factor=3600000000 ;;
				d) factor=86400000000 ;;
				*)
				echo "parse_time: unsupported unit '$unit'" >&2
				return 1
				;;
			esac

			total=$((total + value * factor))
			input="$rest"
		else
			echo "parse_time: invalid duration near '$input'" >&2
			return 1
		fi
	done

	printf '%s\n' "$total"
}

# Format a time in seconds into a human-readable string
format_time() {
	local raw_time="$1"
	local time=$((raw_time / 1000000))  # Convert microseconds to seconds
	local hours=$((time / 3600))
	local minutes=$((time % 3600 / 60))
	local seconds=$((time % 60))

	# Only show the smallest units necessary
	if [[ $hours -gt 0 ]]; then
		printf '%dh' $hours
	fi

	if [[ $minutes -gt 0 || $hours -gt 0 ]]; then
		printf '%dm' $minutes
	fi

	printf '%ds' $seconds
}

fancy_timer() {
	init

	local time=0
	local message="%r remaining"
	local progress=true
	local color="$(bk.term.decorate '%{fg:#FFA500}')"
	local sleep_duration=100000  # Default sleep duration in microseconds (100ms)

	local ansi_invert="\033[7m"
	local ansi_end_invert="\033[27m"
	local ansi_reset="\033[0m"
	local ansi_clear_line="\033[K"

	# Parse arguments
	while [[ $# -gt 0 ]]; do
		case "$1" in
			-h | --help)
				show_usage
				return
				;;
			-v | --version)
				echo "$fancy_timer_version"
				return
				;;
			-c | --color)
				color="$(bk.term.decorate "%{fg:$2}")"
				shift 2
				;;
			-m | --message)
				message="$2"
				shift 2
				;;
			--no-color)
				color=""
				shift
				;;
			--no-progress)
				progress=false
				shift
				;;
			-s | --sleep)
				sleep_duration=$(parse_time "$2")
				if [[ $sleep_duration -le 0 ]]; then
					panic "Invalid sleep duration: $2"
				fi

				echo "Sleep duration set to $(format_time "$sleep_duration")"

				shift 2
				;;
			*)
				time=$(parse_time "$1")
				shift
				;;
		esac
	done

	# Validate arguments
	if [[ $time -eq 0 ]]; then
		echo "Failed to parse time"
		return
	fi

	# Start the timer
	local start_time=$(usec)
	local end_time=$((start_time + time))

	# Main loop
	while [[ $(usec) -lt $end_time ]]; do
		local current_time=$(usec)
		local elapsed_time=$((current_time - start_time))
		local remaining_time=$((end_time - current_time))

		# Calculate the message
		local message_string=${message//\%r/$(format_time $((remaining_time)))}
		message_string=${message_string//\%e/$(format_time $((elapsed_time)))}
		message_string=${message_string//\%t/$(format_time "$time")}

		if $progress; then
			# Calculate the progress. Note that we invert the percentage by not subtracting from 100.
			local progress_percent=$((remaining_time * 100 / time))

			# The progress bar is the width of the terminal
			# We invert the background and foreground colors so it looks like a progress bar
			local column_count=$(tput cols)
			local progress_columns=$((column_count * progress_percent / 100))
			local remaining_columns=$((column_count - progress_columns))

			# Draw the progress bar with the message, adding padding to any remaining space
			printf '\r%b%b%-*.*s%b%-*.*s%b%b' \
				"$color" \
				"$ansi_invert" \
				$progress_columns $progress_columns "$message_string" \
				"$ansi_end_invert" \
				$remaining_columns $remaining_columns "${message_string:progress_columns}" \
				"$ansi_reset" \
				"$ansi_clear_line"
		else
			printf "\r%s" "$message_string"
		fi

		# use the lesser of the sleep duration and the remaining time to avoid overshooting
		local actual_sleep_duration=$((remaining_time < sleep_duration ? remaining_time : sleep_duration))
		usleep "$actual_sleep_duration"
	done

	# Print the elapsed time
	printf "\r%s elapsed%b\n" "$(format_time "$time")" "$ansi_clear_line"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
	fancy_timer "$@"
else
	export -f fancy_timer
fi
